<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Required by ActivityRecognitionClient. Runtime-prompted on API 29+. -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="com.google.android.gms.permission.ACTIVITY_RECOGNITION" />
    <!-- Lets us ask the user to exempt the app from battery optimisation so
         OEM-aggressive battery savers (Xiaomi, Oppo, OnePlus) can't silently
         kill the BackgroundGeolocation foreground service mid-shift. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application>
        <receiver
            android:name="com.secureops.capacitor.activityrecognition.ActivityTransitionReceiver"
            android:exported="false" />
    </application>
</manifest>
