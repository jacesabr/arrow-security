{
  "name": "secureops",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter=!mobile run dev",
    "dev:api": "pnpm --filter=api run dev",
    "dev:tenant": "pnpm --filter=tenant run dev",
    "dev:mobile": "pnpm --filter=mobile run dev",
    "build": "pnpm --recursive run build",
    "db:generate": "pnpm --filter=db run generate",
    "db:push": "pnpm --filter=db run push",
    "db:migrate": "pnpm --filter=db run migrate",
    "db:seed": "pnpm --filter=db run seed",
    "db:setup": "pnpm db:push && pnpm db:seed",
    "db:studio": "pnpm --filter=db run studio"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.1",
      "@types/react-dom": "18.3.1"
    }
  }
}
